# CommandCode Proxy Configuration

# Required: API key clients must send via Authorization: Bearer <key>
PROXY_API_KEY=your-secret-key

# Optional: Server port (default: 8080)
PORT=8080

# Optional: Path to cmd binary (default: "cmd" — looks up in PATH)
CMD_PATH=cmd

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Connection Pooling
MAX_CONCURRENT=4

# Timeouts
REQUEST_TIMEOUT_SEC=300

# Limits
MAX_REQUEST_SIZE_MB=10
MAX_TURNS=10
